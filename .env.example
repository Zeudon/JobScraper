# === LLM Provider Configuration ===
# Provider: "groq" (free, recommended) or "gemini"
LLM_PROVIDER=groq

# Groq (free tier)
GROQ_API_KEY=your_groq_api_key_here
# Default model: openai/gpt-oss-120b — free, 131K context window, and the
# official replacement for llama-3.3-70b-versatile (deprecated for free/dev tier).
# Free-tier limits: ~30 req/min, ~8,000 tokens/min, ~200K tokens/day — keep
# per-request content modest (see the *_CONTENT_CHARS knobs below).
# LLM_MODEL=openai/gpt-oss-120b

# Google Gemini
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-2.5-flash

# === Scraper Settings ===
# Browser mode: "headed" to watch, "headless" to run silently
BROWSER_MODE=headed


# Delay between LLM calls in seconds (prevents rate limits). With gpt-oss-120b's
# 8K tokens/min free-tier cap, 5s is a safer default than 2s for large prompts.
LLM_CALL_DELAY=5

# Maximum age of job postings in days (older jobs are filtered out)
MAX_JOB_AGE_DAYS=30

# Maximum pagination pages per department (e.g. 20 pages of Engineering, then 20 of Data, etc.)
MAX_PAGINATION_PAGES=20

# How much page text (chars) and how many links to send to the LLM per prompt.
# Defaults below are sized for GEMINI's free tier (1M context, 250K TPM). For
# GROQ's 8K-TPM free tier they MUST be much smaller (else HTTP 413): use
# PLAN=5000 / EXTRACT=8000 / DETAIL=6000, PLAN_MAX_LINKS=60 / EXTRACT_MAX_LINKS=80.
# PLAN_CONTENT_CHARS=16000      # careers-page navigation planning
# EXTRACT_CONTENT_CHARS=60000   # job-listing extraction
# DETAIL_CONTENT_CHARS=24000    # per-job relevance judgment
# PLAN_MAX_LINKS=120            # links included in the planning prompt
# EXTRACT_MAX_LINKS=250         # links included in the extraction prompt

# Circuit breaker: after this many LLM calls fail in a row for one company,
# skip that company and move on (instead of grinding through retry backoff).
# MAX_CONSECUTIVE_LLM_FAILURES=2
